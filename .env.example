# Rename this file to .env and fill in your real credentials
# NEVER commit .env to git

# Gmail SMTP (create App Password at https://myaccount.google.com/apppasswords)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_16_char_app_password

# Where order emails go (usually same as MAIL_USER)
OWNER_EMAIL=your_email@gmail.com

# Server port
PORT=3000
